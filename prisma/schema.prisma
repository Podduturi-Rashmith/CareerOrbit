generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  SCREENING_CALL
  INTERVIEW
  ASSESSMENT
  REJECTED
  OFFER
}

enum UpcomingEventType {
  SCREENING
  INTERVIEW
  ASSESSMENT
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  role         UserRole
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  student      Student?
  admin        Admin?
  sessions     Session[]
  applications Application[] @relation("StudentApplications")
  tailoredResumes TailoredResume[] @relation("TailoredResumeOwner")
}

model Student {
  id             String @id @default(cuid())
  userId         String @unique
  major          String
  graduationYear Int
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id      String @id @default(cuid())
  userId  String @unique
  adminId String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id              String            @id @default(cuid())
  studentUserId   String
  companyName     String
  jobRole         String
  status          ApplicationStatus
  resumeUrl       String?
  upcomingEventType UpcomingEventType?
  upcomingEventDate DateTime?
  meetingLink     String?
  prepNotes       String?
  applicationDate DateTime
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  student         User              @relation("StudentApplications", fields: [studentUserId], references: [id], onDelete: Cascade)

  @@index([studentUserId])
  @@unique([studentUserId, companyName, jobRole])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model JobListing {
  id            String   @id @default(cuid())
  source        String
  externalId    String
  title         String
  company       String
  location      String?
  roleCategory  String
  workMode      String?
  description   String
  applyUrl      String
  postedAt      DateTime
  fetchedAt     DateTime @default(now())
  isNew         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tailoredResumes TailoredResume[]

  @@unique([source, externalId])
  @@index([roleCategory])
  @@index([postedAt])
}

model JobFetchRun {
  id          String   @id @default(cuid())
  provider    String
  status      String
  fetchedCount Int
  newCount    Int
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  error       String?
}

model TailoredResume {
  id            String   @id @default(cuid())
  jobId          String
  studentEmail   String
  studentName    String
  roleCategory   String
  summary        String
  generatedById  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  job            JobListing @relation(fields: [jobId], references: [id], onDelete: Cascade)
  generatedBy    User? @relation("TailoredResumeOwner", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([studentEmail])
}
